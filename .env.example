# App
APP_NAME=retail-recommender-mlops
APP_ENV=local
LOG_LEVEL=INFO

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# PostgreSQL local
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=retail_recommender
POSTGRES_USER=retail_user
POSTGRES_PASSWORD=retail_password

# SQLAlchemy connection string
DATABASE_URL=postgresql+psycopg2://retail_user:retail_password@localhost:5432/retail_recommender

# Google Cloud / Vertex AI
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_BUCKET_NAME=
VERTEX_ENDPOINT_ID=

# Auth for protected routes
JWT_SECRET_KEY=change_me_in_local_env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
